//The core of the enemy movement and attack and generation.

//----- Green flag events ---------------------------------------------------------------------------------------------

WhenGreenFlagClicked()
{
    List.DeleteAll(attacksoundeffects);
    Forever
    {
        If (List.Length(attacksoundeffects) > 0)
        {
            Sound.Play(attacksoundeffects[1]);
            If (attacksoundeffects[1] == 0)
            {
                Control.Wait(0.1);
            }
            List.DeleteItem(attacksoundeffects, 1);
        }
    }
}


//----- Broadcast received events -------------------------------------------------------------------------------------

WhenBroadcastReceived(Advance) //Generate enemies
{
    Call Mon Gen;
}

WhenBroadcastReceived(EnemyMovement) //Enemies' turn
{
    Call Move Enemies;
}
 
WhenBroadcastReceived(Monster) //Generate 1 monster
{
    If (Not (((floor == 26) Or (floor == 40))))
    {
        Call Generate 1 Mon(Operator.LetterOf(monster table[floor], Operator.Random(1 , Variable.Length(monster table[floor]))));
    }
}

WhenBroadcastReceived(StartGame) //Generate enemies
{
    Call Mon Gen;
}


