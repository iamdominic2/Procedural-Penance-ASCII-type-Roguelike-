                                                        If (Operator.Random(1 , 3) == 1)
                                                        {
                                                            If (List.ContainsItem(monstermaploc, "I") Or List.ContainsItem(monstermaploc, "P"))
                                                            {
                                                                Call Attack or move;
                                                            }
                                                            Else
                                                            {
                                                                List.Add(textlog, "Queen summoned monsters.");
                                                                Call Generate 1 Mon("P");
                                                                Call Generate 1 Mon("I");
                                                            }
                                                        }
                                                        Else
                                                        {
                                                            Looks.SwitchCostumeTo(Q);
                                                            If (Operator.Random(1 , 3) == 1)
                                                            {
                                                                List.Add(textlog, "Queen threw a rock.");
                                                                dmg = Operator.Round((Operator.Random(0.5 , 0.6) * (Operator.Join(Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 1), Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 2)) - PlayerShieldStrength)));
                                                                List.Add(attacksoundeffects, 1);
                                                                List.Add(textlog, Operator.Join(Operator.Join(Operator.Join("Took ", dmg), " damage from "), Operator.Join(MonsterNames[(Costume.GetNumberName(number) - 17)], ".")));
                                                                PlayerHp += (-1 * dmg);
                                                            }
                                                            Else
                                                            {
                                                                If List.ContainsItem(1tiler, (counter7 - Playerloc))
                                                                {
                                                                    List.Add(textlog, "Queen stabbed you with poison.");
                                                                    dmg = Operator.Round((Operator.Random(0.7 , 0.8) * (Operator.Join(Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 1), Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 2)) - PlayerShieldStrength)));
                                                                    List.Add(attacksoundeffects, 1);
                                                                    List.Add(textlog, Operator.Join(Operator.Join(Operator.Join("Took ", dmg), " damage from "), Operator.Join(MonsterNames[(Costume.GetNumberName(number) - 17)], ".")));
                                                                    PlayerHp += (-1 * dmg);
                                                                    If (PlayerPower > 2)
                                                                    {
                                                                        If (Not ((inventory[List.IndexOf(equipped, "Armband")] == 15)))
                                                                        {
                                                                            List.Add(textlog, "Power went down 2.");
                                                                            PlayerPower += -2;
                                                                        }
                                                                        Else
                                                                        {
                                                                            List.Add(textlog, "Your armband prevented power loss.");
                                                                        }
                                                                    }
                                                                }
                                                                Else
                                                                {
                                                                    Call Attack or move;
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                                Else
                                                {
                                                    Call Attack or move;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            Else
                            {
                                Call Attack or move;
                            }
                        }
                    }
                }
            }
            If (monstermaploc[counter7] == "I") //This monster cannot be statused
            {
                If (Not ((Monstercondition[counter7] == "")))
                {
                    List.Add(textlog, "Immunacrab nullifies status!");
                    List.ReplaceItem(Monstercondition, counter7, "");
                }
            }
            Else
            {
            }
            If ((Monstercondition[counter7] < 1000) And (Monstercondition[counter7] > -200))
            {
                List.ReplaceItem(Monstercondition, counter7, (Monstercondition[counter7] - 1));
            }
        }
        counter6 += 1;
    }
}

Define Move enemy tile no.(string old) to(string new) (warp=false) //Translocation of monster from one place to another
{
    If (((Not ((Operator.LetterOf(maps[floor], new) == 4))) And (Not ((monstermaploc[new] > "")))) And (Not ((new == Playerloc))))
    {
        List.ReplaceItem(monstermaploc, new, monstermaploc[old]);
        List.ReplaceItem(monsterhp, new, monsterhp[old]);
        List.ReplaceItem(Monstercondition, new, Monstercondition[old]);
        List.ReplaceItem(monstermaploc, old, "");
        List.ReplaceItem(Monstercondition, old, "");
        List.ReplaceItem(monsterhp, old, "");
        counter7 = new;
        List.ReplaceItem(monstergoaltiles, new, "!");
    }
}

Define Unequip equipment (warp=false) //Final boss attack
{
    List.Add(textlog, "Your equipment was unequiped!");
    List.ReplaceItem(equipped, List.IndexOf(equipped, "Sword"), 0);
    List.ReplaceItem(equipped, List.IndexOf(equipped, "Shield"), 0);
    List.ReplaceItem(equipped, List.IndexOf(equipped, "Armband"), 0);
}


