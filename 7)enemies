Define Attack or move (warp=false)
{
    If (List.ContainsItem(1tiler, (counter7 - Playerloc)) And ((Not (((Monstercondition[counter7] > 100) And (Monstercondition[counter7] < 120)))) Or (Operator.Random(1 , 3) == 1)))
    {
        Looks.SwitchCostumeTo(monstermaploc[counter7]);
        If ((Costume.GetNumberName(name) == "F") And (Monstercondition[counter7] == ""))
        {
            dmg = (10 / ((inventory[List.IndexOf(equipped, "Shield")] == 14) + 1));
            List.Add(textlog, "Firepuff breathed fire.");
        }
        Else
        {
            If (Operator.Random(1 , (20 / (((inventory[List.IndexOf(equipped, "Shield")] == 9) * 4) + 1))) == 1)
            {
                dmg = 0.01;
                If ((inventory[List.IndexOf(equipped, "Shield")] == 9) And (Operator.Random(1 , 5) < 5))
                {
                    List.Add(textlog, "Your shield makes you hard to hit!");
                }
            }
            Else
            {
                If ((monstermaploc[counter7] == "P") And (Operator.Random(1 , 5) == 1))
                {
                    dmg = Operator.Round((Operator.Random(1.8 , 2) * (Operator.Join(Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 1), Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 2)) - PlayerShieldStrength)));
                    List.Add(attacksoundeffects, 2);
                    List.Add(textlog, "Punisher struck painfully!");
                }
                Else
                {
                    dmg = Operator.Round((Operator.Random(0.9 , 1) * (Operator.Join(Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 1), Operator.LetterOf(monster stats[(Costume.GetNumberName(number) - 17)], 2)) - PlayerShieldStrength)));
                }
            }
        }
        If (dmg > 0.01)
        {
            If (((PlayerHp % 10) == 0) Or ((PlayerHp % 10) == 1))
            {
                If (inventory[List.IndexOf(equipped, "Shield")] == 10)
                {
                    List.Add(textlog, "The Binary Shield reduced the damage!");
                    dmg = (dmg * 0.6);
                }
            }
            List.Add(attacksoundeffects, 1);
            List.Add(textlog, Operator.Join(Operator.Join(Operator.Join("Took ", dmg), " damage from "), Operator.Join(MonsterNames[(Costume.GetNumberName(number) - 17)], ".")));
            PlayerHp += (-1 * dmg);
        }
        Else
        {
            If (dmg == 0.01)
            {
                If (Not ((MonsterNames[(Costume.GetNumberName(number) - 17)] == "")))
                {
                    List.Add(attacksoundeffects, 3);
                    List.Add(textlog, Operator.Join(MonsterNames[(Costume.GetNumberName(number) - 17)], "'s attack missed."));
                }
            }
            Else
            {
                If (Not ((MonsterNames[(Costume.GetNumberName(number) - 17)] == "")))
                {
                    If (inventory[List.IndexOf(equipped, "Shield")] == 10)
                    {
                        List.Add(textlog, "The Binary Shield reduced the damage!");
                    }
                    List.Add(attacksoundeffects, 1);
                    List.Add(textlog, Operator.Join(Operator.Join(Operator.Join("Took ", 1), " damage from "), Operator.Join(MonsterNames[(Costume.GetNumberName(number) - 17)], ".")));
                    PlayerHp += -1;
                    dmg = 1;
                }
            }
        }
        List.Add(attacksoundeffects, 0);
        If (inventory[List.IndexOf(equipped, "Shield")] == 8)
        {
            If ((Not ((Costume.GetNumberName(name) == "F"))) And (dmg > 0.01))
            {
                List.ReplaceItem(monsterhp, counter7, (monsterhp[counter7] - ceiling((dmg / 3.5))));
                List.Add(textlog, Operator.Join(Operator.Join("Counter Shield dealt ", ceiling((dmg / 3.5))), Operator.Join(Operator.Join(" damage to ", MonsterNames[(Costume.GetNumberName(number) - 17)]), ".")));
                List.Add(attacksoundeffects, 5);
                List.Add(attacksoundeffects, 0);
                If (monsterhp[counter7] < 1)
                {
                    Sound.Play(PunchKill);
                    List.Add(textlog, Operator.Join(MonsterNames[List.IndexOf(al, monstermaploc[counter7])], " died."));
                    List.Add(textlog, Operator.Join(Operator.Join("Gained ", Operator.Round(Operator.Join(Operator.Join(Operator.Join(Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 8), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 9)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 10)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 11)))), " Exp."));
                    PlayerExp += Operator.Join(Operator.Join(Operator.Join(Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 8), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 9)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 10)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter7])], 11));
                    PlayerScorept1 += 125;
                    List.ReplaceItem(monstermaploc, counter7, "");
                    List.ReplaceItem(Monstercondition, counter7, "");
                    List.ReplaceItem(monsterhp, counter7, "");
                }
            }
        }
    }
    Else
    {
        If ((Monstercondition[counter7] > 100) And (Monstercondition[counter7] < 120))
        {
            Call Move enemy tile no.(counter7) to((counter7 + 1tiler[random]));
        }
        Else
        {
            If (playery > countery)
            {
                Call Move enemy tile no.(counter7) to((counter7 + 1));
            }
            Else
            {
                If (playery < countery)
                {
                    Call Move enemy tile no.(counter7) to((counter7 - 1));
                }
            }
            counterx = (floor(((counter7 / 40) - 0.00001)) + 1);
            countery = ((counter7 % 40) + 1);
            If (counterx > playerx)
            {
                Call Move enemy tile no.(counter7) to((counter7 - 40));
            }
            Else
            {
                If (counterx < playerx)
                {
                    Call Move enemy tile no.(counter7) to((counter7 + 40));
                }
            }
        }
    }
}

Define CheckD(string loc) (warp=false) //Check direction of alignment
{
    counter1 = 0;
    Repeat (8)
    {
        counter1 += 1;
        projectiletile = loc;
        projectiletile += 1tiler[counter1];
        Repeat Until (((monstermaploc[projectiletile] > "") Or (projectiletile == Playerloc)) Or (Operator.LetterOf(maps[floor], projectiletile) == 4))
        {
            projectiletile += 1tiler[counter1];
        }
        If (projectiletile == Playerloc)
        {
            counter1 = -1;
            Stop(this script);
        }
    }
}

Define Generate 1 Mon(string t) (warp=true) //New monster spawns
{
    counter4 = 0;
    Repeat Until (((Operator.LetterOf(maps[floor], counter4) == 2) And (Not ((monsterhp[counter4] > "")))) And (Not ((counter4 == Playerloc))))
    {
        counter4 = Operator.Random(1 , 2360);
    }
    List.ReplaceItem(monstermaploc, counter4, t);
    List.ReplaceItem(monsterhp, counter4, Operator.Join(Operator.Join(Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter4])], 5), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter4])], 6)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[counter4])], 7)));
    List.ReplaceItem(Monstercondition, counter4, "");
}

Define Mon Gen (warp=true) //Generate a list of monsters while erasing the old ones.
{
    List.DeleteAll(monstermaploc);
    List.DeleteAll(monsterhp);
    List.DeleteAll(Monstercondition);
    Repeat (2360)
    {
        List.Add(monstermaploc, "");
        List.Add(monsterhp, "");
        List.Add(Monstercondition, "");
    }
    Repeat (((((Operator.Round(sqrt((floor - 1))) + 1) * (Not (((floor == 26) Or (floor == 40))))) + 1) + (List.ContainsItem(MH floors, floor) * 14)))
    {
        Call Generate 1 Mon(Operator.LetterOf(monster table[floor], Operator.Random(1 , Variable.Length(monster table[floor]))));
    }
}

Define Move Enemies (warp=true) //Monsters move around
{
    counter6 = 1;
    List.DeleteAll(monstergoaltiles);
    Repeat (2360)
    {
        List.Add(monstergoaltiles, "");
    }
    Repeat (2360)
    {
        playerx = (floor(((Playerloc / 40) - 0.00001)) + 1);
        playery = ((Playerloc % 40) + 1);
        counterx = (floor(((counter6 / 40) - 0.00001)) + 1);
        countery = ((counter6 % 40) + 1);
