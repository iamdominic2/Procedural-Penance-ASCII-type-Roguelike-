//----- Green flag events ---------------------------------------------------------------------------------------------

WhenGreenFlagClicked()
{
    Forever
    {
        If (inventoryopen == 1)
        {
            If Sensing.KeyPressed(x)
            {
                selectioninv = 0;
                Wait Until (Not (Sensing.KeyPressed(x)));
            }
            If Sensing.KeyPressed(z)
            {
                If (selectioninv == 0)
                {
                    selectioninv = 1;
                    selectioninv2 = 1;
                    Wait Until (Not (Sensing.KeyPressed(z)));
                }
                Else
                {
                    If (selectioninv2 == 3)
                    {
                        List.Add(textlog, items[inventory[ihover]]);
                        List.Add(textlog, ItemDesc[inventory[ihover]]);
                        Wait Until (Not (Sensing.KeyPressed(z)));
                    }
                    If (selectioninv2 == 2)
                    {
                        If (mapitems[Playerloc] == "")
                        {
                            List.Add(textlog, Operator.Join(Operator.Join("Dropped ", Operator.Join(items[inventory[ihover]], inventorycount[ihover])), "."));
                            List.ReplaceItem(mapitems, Playerloc, inventory[ihover]);
                            List.ReplaceItem(flooritemmount, Playerloc, Operator.Round(inventorycount[ihover]));
                            List.DeleteItem(inventory, ihover);
                            List.DeleteItem(inventorycount, ihover);
                            List.DeleteItem(equipped, ihover);
                            Event.Broadcast("PastTurn");
                            inventoryopen = 2;
                            Control.Wait(0);
                            Wait Until (Not (Sensing.KeyPressed(z)));
                            selectioninv = 0;
                            selectioninv2 = 1;
                            inventoryopen = 0;
                        }
                        Else
                        {
                            Sound.Play(Collect);
                            List.Add(inventory, mapitems[Playerloc]);
                            If (flooritemmount[Playerloc] < 1)
                            {
                                List.Add(inventorycount, "");
                            }
                            Else
                            {
                                List.Add(inventorycount, Operator.Join("+", flooritemmount[Playerloc]));
                            }
                            List.Add(equipped, 0);
                            If (inventorycount[List.Length(inventorycount)] > 0)
                            {
                                List.Add(textlog, Operator.Join(Operator.Join("Swapped ", Operator.Join(items[mapitems[Playerloc]], Operator.Join("+", flooritemmount[Playerloc]))), ""));
                            }
                            Else
                            {
                                List.Add(textlog, Operator.Join(Operator.Join("Swapped ", items[mapitems[Playerloc]]), ""));
                            }
                            List.Add(textlog, Operator.Join(Operator.Join("with ", Operator.Join(items[inventory[ihover]], inventorycount[ihover])), "."));
                            List.ReplaceItem(mapitems, Playerloc, inventory[ihover]);
                            List.ReplaceItem(flooritemmount, Playerloc, Operator.Round(inventorycount[ihover]));
                            List.DeleteItem(inventory, ihover);
                            List.DeleteItem(inventorycount, ihover);
                            List.DeleteItem(equipped, ihover);
                            Event.Broadcast("PastTurn");
                            inventoryopen = 2;
                            Control.Wait(0);
                            Wait Until (Not (Sensing.KeyPressed(z)));
                            selectioninv = 0;
                            selectioninv2 = 1;
                            inventoryopen = 0;
                        }
                    }
                    Else
                    {
                        If (selectioninv2 == 1)
                        {
                            If (equipped[ihover] > 0)
                            {
                                Sound.Play(Unequip);
                                List.Add(textlog, Operator.Join("You ", Operator.Join("unequiped", Operator.Join(" ", Operator.Join(Operator.Join(items[inventory[ihover]], inventorycount[ihover]), ".")))));
                            }
                            Else
                            {
                                List.Add(textlog, Operator.Join("You ", Operator.Join(PastVerbs[List.IndexOf(PresentVerbs, itemverb[inventory[ihover]])], Operator.Join(" ", Operator.Join(Operator.Join(items[inventory[ihover]], inventorycount[ihover]), ".")))));
                            }
                            If (itemverb[inventory[ihover]] == "equip")
                            {
                                Sound.Play(Equip);
                            }
                            If (itemverb[inventory[ihover]] == "eat")
                            {
                                Sound.Play(Chomp);
                            }
                            If (itemverb[inventory[ihover]] == "read")
                            {
                                Sound.Play(Read);
                            }
                            If (inventory[ihover] == 49)
                            {
                                If (PlayerFull < (PlayerMaxFull - 50))
                                {
                                    PlayerFull += 50;
                                    List.Add(textlog, "Fullness increased.");
                                }
                                Else
                                {
                                    If (PlayerFull == PlayerMaxFull)
                                    {
                                        PlayerMaxFull += 2;
                                        PlayerFull += 2;
                                        List.Add(textlog, "Maximum fullness increased by 2.");
                                    }
                                    Else
                                    {
                                        PlayerFull = PlayerMaxFull;
                                        List.Add(textlog, "You're totally full.");
                                    }
                                }
                            }
                            Else
                            {
                                If (inventory[ihover] == 50)
                                {
                                    If (PlayerFull == PlayerMaxFull)
                                    {
                                        PlayerMaxFull += 5;
                                        PlayerFull += 5;
                                        List.Add(textlog, "Maximum fullness increased by 5.");
                                    }
                                    Else
                                    {
                                        PlayerFull = PlayerMaxFull;
                                        List.Add(textlog, "You're totally full.");
                                    }
                                }
                                Else
                                {
                                    If (inventory[ihover] == 25)
                                    {
                                        If (PlayerHp == PlayerMaxHp)
                                        {
                                            PlayerAdditionalHp += 2;
                                            PlayerMaxHp += 2;
                                            List.Add(textlog, "Max HP rose by 2.");
                                        }
                                        Else
                                        {
                                            List.Add(textlog, "Recovered 40 HP.");
                                        }
                                        PlayerHp += 40;
                                        If (PlayerHp > PlayerMaxHp)
                                        {
                                            PlayerHp = PlayerMaxHp;
                                        }
                                    }
                                    Else
                                    {
                                        If (inventory[ihover] == 26)
                                        {
                                            If (PlayerHp == PlayerMaxHp)
                                            {
                                                PlayerAdditionalHp += 3;
                                                PlayerMaxHp += 3;
                                                List.Add(textlog, "Max HP rose by 3.");
                                            }
                                            Else
                                            {
                                                List.Add(textlog, "Recovered 100 HP.");
                                            }
                                            PlayerHp += 100;
                                            If (PlayerHp > PlayerMaxHp)
                                            {
                                                PlayerHp = PlayerMaxHp;
                                            }
                                        }
                                        Else
                                        {
                                            If (inventory[ihover] == 27)
                                            {
                                                List.Add(textlog, "Max HP rose by 5.");
                                                PlayerAdditionalHp += 5;
                                                PlayerHp += 5;
                                            }
                                            Else
                                            {
                                                If (inventory[ihover] == 31)
                                                {
                                                    PlayerExp = exp table[PlayerLevel];
                                                }
                                                Else
                                                {
                                                    If (inventory[ihover] == 32)
                                                    {
                                                        List.Add(textlog, "Power rose by 1.");
                                                        PlayerPower += 1;
                                                    }
                                                    Else
                                                    {
                                                        If (inventory[ihover] == 40)
                                                        {
                                                            List.Add(textlog, "You can now see the layout of the floor.");
                                                            floorlight = 1;
                                                            Call RevealMap;
                                                        }
                                                        Else
                                                        {
                                                            If (inventory[ihover] < 8)
                                                            {
                                                                If (equipped[ihover] > 0)
                                                                {
                                                                    List.ReplaceItem(equipped, List.IndexOf(equipped, "Sword"), 0);
                                                                }
                                                                Else
                                                                {
                                                                    List.ReplaceItem(equipped, List.IndexOf(equipped, "Sword"), 0);
                                                                    List.ReplaceItem(equipped, ihover, "Sword");
                                                                }
                                                            }
                                                            Else
                                                            {
                                                                If (inventory[ihover] < 15)
                                                                {
                                                                    If (equipped[ihover] > 0)
                                                                    {
                                                                        List.ReplaceItem(equipped, List.IndexOf(equipped, "Shield"), 0);
                                                                    }
                                                                    Else
                                                                    {
                                                                        List.ReplaceItem(equipped, List.IndexOf(equipped, "Shield"), 0);
                                                                        List.ReplaceItem(equipped, ihover, "Shield");
                                                                    }
                                                                }
                                                                Else
                                                                {
                                                                    If (inventory[ihover] < 25)
                                                                    {
                                                                        If (equipped[ihover] > 0)
                                                                        {
                                                                            List.ReplaceItem(equipped, List.IndexOf(equipped, "Armband"), 0);
                                                                        }
                                                                        Else
                                                                        {
                                                                            List.ReplaceItem(equipped, List.IndexOf(equipped, "Armband"), 0);
                                                                            List.ReplaceItem(equipped, ihover, "Armband");
                                                                        }
                                                                    }
                                                                    Else
                                                                    {
                                                                        If (inventory[ihover] == 48)
                                                                        {
                                                                            List.Add(textlog, "Your attack power increased.");
                                                                            PlayerPowerUps += 0.5;
                                                                        }
                                                                        Else
                                                                        {
                                                                            If (inventory[ihover] == 28)
                                                                            {
                                                                                Call Warp;
                                                                                Playerloc = counter1;
                                                                                List.Add(textlog, "You warped.");
                                                                            }
                                                                            Else
                                                                            {
                                                                                If (inventory[ihover] == 41)
                                                                                {
                                                                                    List.ReplaceItem(inventorycount, List.IndexOf(equipped, "Sword"), Operator.Join("+", (1 + inventorycount[List.IndexOf(equipped, "Sword")])));
                                                                                    If (List.IndexOf(equipped, "Sword") == 0)
                                                                                    {
                                                                                        List.Add(textlog, "Could not upgrade your weapon.");
                                                                                    }
                                                                                    Else
                                                                                    {
                                                                                        List.Add(textlog, "Equipped weapon upgraded.");
                                                                                        If (Operator.Random(1 , 13) == 1)
                                                                                        {
                                                                                            List.Add(textlog, "Lucky! Weapon was further strengthened.");
                                                                                            List.ReplaceItem(inventorycount, List.IndexOf(equipped, "Sword"), Operator.Join("+", (2 + inventorycount[List.IndexOf(equipped, "Sword")])));
                                                                                        }
                                                                                    }
                                                                                }
                                                                                Else
                                                                                {
                                                                                    If (inventory[ihover] == 42)
                                                                                    {
                                                                                        List.ReplaceItem(inventorycount, List.IndexOf(equipped, "Shield"), Operator.Join("+", (1 + inventorycount[List.IndexOf(equipped, "Shield")])));
                                                                                        If (List.IndexOf(equipped, "Shield") == 0)
                                                                                        {
                                                                                            List.Add(textlog, "Could not upgrade your shield.");
                                                                                        }
                                                                                        Else
                                                                                        {
                                                                                            List.Add(textlog, "Equipped shield upgraded.");
                                                                                            If (Operator.Random(1 , 13) == 1)
                                                                                            {
                                                                                                List.Add(textlog, "Lucky! Shield was further strengthened.");
                                                                                                List.ReplaceItem(inventorycount, List.IndexOf(equipped, "Shield"), Operator.Join("+", (2 + inventorycount[List.IndexOf(equipped, "Shield")])));
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                    Else
                                                                                    {
                                                                                        If (inventory[ihover] == 47)
                                                                                        {
                                                                                            List.Add(textlog, "You exploded!");
                                                                                            List.Add(textlog, Operator.Join("Took ", Operator.Join(Operator.Round((PlayerHp / (2 * ((inventory[List.IndexOf(equipped, "Shield")] == 14) + 1)))), " damage.")));
                                                                                            PlayerHp += Operator.Round((PlayerHp / (-2 * ((inventory[List.IndexOf(equipped, "Shield")] == 14) + 1))));
                                                                                            counter1 = 0;
                                                                                            Call Explosion;
                                                                                        }
                                                                                        Else
                                                                                        {
                                                                                            If (inventory[ihover] == 46)
                                                                                            {
                                                                                                Sound.Play(Lightning);
                                                                                                Call Lightning;
                                                                                            }
                                                                                            Else
                                                                                            {
                                                                                                If (inventory[ihover] == 44)
                                                                                                {
                                                                                                    Sound.Play(Snoring);
                                                                                                    Call Scatter(210) text(" fell asleep!");
                                                                                                }
                                                                                                Else
                                                                                                {
                                                                                                    If (inventory[ihover] == 43)
                                                                                                    {
                                                                                                        Sound.Play(Confusion);
                                                                                                        Call Scatter(116) text(" was dazed!");
                                                                                                    }
                                                                                                    Else
                                                                                                    {
                                                                                                        If (inventory[ihover] == 45)
                                                                                                        {
                                                                                                            List.Add(textlog, "Recovered HP.");
                                                                                                            PlayerHp = PlayerMaxHp;
                                                                                                            Call Paralyze nearby;
                                                                                                            If (player's status > 1)
                                                                                                            {
                                                                                                                player's status = 0;
                                                                                                                List.Add(textlog, "You got oriented.");
                                                                                                            }
                                                                                                            If (PlayerPower < 8)
                                                                                                            {
                                                                                                                PlayerPower = 8;
                                                                                                                List.Add(textlog, "Power returned to normal.");
                                                                                                            }
                                                                                                            If (PlayerFull < 1)
                                                                                                            {
                                                                                                                PlayerFull = PlayerMaxFull;
                                                                                                                List.Add(textlog, "You're totally full.");
                                                                                                            }
                                                                                                        }
                                                                                                        Else
                                                                                                        {
                                                                                                            If List.ContainsItem(projectile items, inventory[ihover])
                                                                                                            {
                                                                                                                projectiletile = Playerloc;
                                                                                                                Call Fire Projectile;
                                                                                                            }
                                                                                                            Else
                                                                                                            {
                                                                                                                If (inventory[ihover] == 30)
                                                                                                                {
                                                                                                                    List.Add(textlog, "You should carry this, as opposed to eating it.");
                                                                                                                }
                                                                                                            }
                                                                                                        }
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                            PlayerWeaponStrength = (((weapon/shield power[inventory[List.IndexOf(equipped, "Weapon")]] + inventorycount[List.IndexOf(equipped, "Weapon")]) * 1) / 1.25);
                            PlayerShieldStrength = (((weapon/shield power[inventory[List.IndexOf(equipped, "Shield")]] + inventorycount[List.IndexOf(equipped, "Shield")]) * 1) / 1.5625);
                            Event.Broadcast("PastTurn");
                            If ((itemverb[inventory[ihover]] == "Eat") And (inventory[ihover] < 48))
                            {
                                If (PlayerFull < (PlayerMaxFull - 5))
                                {
                                    PlayerFull += 5;
                                }
                                Else
                                {
                                    PlayerFull = PlayerMaxFull;
                                }
                            }
                            If (itemverb[inventory[ihover]] == "Swing")
                            {
                                Sound.Play(Swish Effect2);
                                List.ReplaceItem(inventorycount, ihover, Operator.Join("+", (inventorycount[ihover] - 1)));
                                If (inventorycount[ihover] < 1)
                                {
                                    List.Add(textlog, "The staff broke.");
                                    List.DeleteItem(inventory, ihover);
                                    List.DeleteItem(inventorycount, ihover);
                                    List.DeleteItem(equipped, ihover);
                                }
                            }
                            If ((itemverb[inventory[ihover]] == "Eat") Or (itemverb[inventory[ihover]] == "Read"))
                            {
                                List.DeleteItem(inventory, ihover);
                                List.DeleteItem(inventorycount, ihover);
                                List.DeleteItem(equipped, ihover);
                            }
                            inventoryopen = 2;
                            Control.Wait(0);
                            Wait Until (Not (Sensing.KeyPressed(z)));
                            selectioninv = 0;
                            selectioninv2 = 1;
                            inventoryopen = 0;
                        }
                    }
                }
            }
            If (selectioninv == 1)
            {
                If (Sensing.KeyPressed(down arrow) And (selectioninv2 < 3))
                {
                    selectioninv2 += 1;
                    Wait Until (Not (Sensing.KeyPressed(down arrow)));
                }
                If (Sensing.KeyPressed(up arrow) And (selectioninv2 > 1))
                {
                    selectioninv2 += -1;
                    Wait Until (Not (Sensing.KeyPressed(up arrow)));
                }
            }
            Else
            {
                If (Sensing.KeyPressed(down arrow) And List.ContainsItem(downhover, ihover))
                {
                    ihover += 1;
                    Wait Until (Not (Sensing.KeyPressed(down arrow)));
                }
                If (Sensing.KeyPressed(up arrow) And List.ContainsItem(uphover, ihover))
                {
                    ihover += -1;
                    Wait Until (Not (Sensing.KeyPressed(up arrow)));
                }
                If (Sensing.KeyPressed(right arrow) And (ihover < 17))
                {
                    ihover += 4;
                    Wait Until (Not (Sensing.KeyPressed(right arrow)));
                }
                If (Sensing.KeyPressed(left arrow) And (ihover > 4))
                {
                    ihover += -4;
                    Wait Until (Not (Sensing.KeyPressed(left arrow)));
                }
            }
        }
    }
}

