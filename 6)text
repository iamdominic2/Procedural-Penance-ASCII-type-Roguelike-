                        }
                        Else
                        {
                            Call Write(Operator.Join("Def:", Operator.Join((weapon/shield power[inventory[List.IndexOf(equipped, "Shield")]] + inventorycount[List.IndexOf(equipped, "Shield")]), Operator.Join("->", (weapon/shield power[inventory[ihover]] + inventorycount[ihover]))))) at(185)(140);
