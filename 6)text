Define Write(string number or text) at(string x)(string y) (warp=true)
{
    Looks.SwitchCostumeTo(abc);
    Looks.SetSizeTo(48);
    Looks.Show();
    Motion.GoToXY(x, y);
    If (Motion.YPosition() > 11)
    {
        Motion.ChangeXBy(5);
    }
    counter1 = 0;
    Repeat (Variable.Length(number or text))
    {
        counter1 += 1;
        Looks.SwitchCostumeTo(Operator.LetterOf(number or text, counter1));
        If (Costume.GetNumberName(number) < 13)
        {
            Looks.SetEffectTo(BRIGHTNESS, 0);
            Looks.SwitchCostumeTo(abc);
            Looks.SetSizeTo(45);
        }
        Else
        {
            Looks.SetEffectTo(BRIGHTNESS, 100);
            Looks.SwitchCostumeTo(abc);
            Looks.SetSizeTo(48);
        }
        Looks.SwitchCostumeTo(Operator.LetterOf(number or text, counter1));
        Pen.Stamp();
        Motion.ChangeXBy(4.6);
    }
    Looks.Hide();
}


