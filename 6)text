    Call Write(textlog[(scrollingoffset - 2)]) at(-233)((-140 + ((scrollingoffset % 1) * 9)));
    Call Write(textlog[(scrollingoffset - 1)]) at(-233)((-149 + ((scrollingoffset % 1) * 9)));
    Call Write(textlog[scrollingoffset]) at(-233)((-158 + ((scrollingoffset % 1) * 9)));
    Call Write(textlog[(scrollingoffset + 1)]) at(-233)((-167 + ((scrollingoffset % 1) * 9)));
}


//----- Custom blocks -------------------------------------------------------------------------------------------------

Define Explosion (warp=true)
{
    Sound.Play(Explosion);
    Repeat (9)
    {
        counter1 += 1;
        If (monstermaploc[(Playerloc + 1tiler[counter1])] > "")
        {
            List.Add(textlog, Operator.Join(Operator.Join("Dealt 100 damage to ", MonsterNames[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])]), "."));
            List.ReplaceItem(monsterhp, (Playerloc + 1tiler[counter1]), (monsterhp[(Playerloc + 1tiler[counter1])] - 100));
            If (monsterhp[(Playerloc + 1tiler[counter1])] < 1)
            {
                Sound.Play(PunchKill2);
                List.Add(textlog, Operator.Join(Operator.Join(MonsterNames[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], " died"), "."));
                List.Add(textlog, Operator.Join(Operator.Join("Gained ", Operator.Round(Operator.Join(Operator.Join(Operator.Join(Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 8), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 9)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 10)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 11)))), " Exp."));
                PlayerExp += Operator.Join(Operator.Join(Operator.Join(Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 8), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 9)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 10)), Operator.LetterOf(monster stats[List.IndexOf(al, monstermaploc[(Playerloc + 1tiler[counter1])])], 11));
                PlayerScorept1 += 125;
                List.ReplaceItem(monstermaploc, (Playerloc + 1tiler[counter1]), "");
                List.ReplaceItem(monsterhp, (Playerloc + 1tiler[counter1]), "");
                List.ReplaceItem(Monstercondition, (Playerloc + 1tiler[counter1]), "");
            }
        }
    }
}

Define Fire Projectile (warp=true)
{
    If (inventory[ihover] == 29)
    {
        Sound.Play(Fire);
    }
    Repeat Until ((monstermaploc[projectiletile] > "") Or (Operator.LetterOf(maps[floor], projectiletile) == 4))
    {
        projectiletile += PlayerDPointTile;
    }
    If (Operator.LetterOf(maps[floor], projectiletile) == 4)
    {
        Stop(this script);
    }
    Call Projectile Effect;
}

Define I item(string ?) at(string x)(string y) (warp=false)
{
    If ((ihover == ?) And (inventoryopen == 1))
    {
        If (equipped[?] > 0)
        {
            Call Write(Operator.Join(">]", Operator.Join(items[inventory[?]], inventorycount[?]))) at((x - 4.3))(y);
        }
        Else
        {
            Call Write(Operator.Join(">", Operator.Join(items[inventory[?]], inventorycount[?]))) at((x - 4.3))(y);
        }
    }
    Else
    {
